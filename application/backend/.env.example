# Fabric-Trace 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# JWT 配置
# JWT 签名密钥（生产环境请使用强随机密钥，至少32字符）
FABRIC_TRACE_JWT_SECRET=your-strong-jwt-secret-key-at-least-32-characters

# MySQL 配置
# MySQL 密码
FABRIC_TRACE_MYSQL_PASSWORD=your-mysql-password

# 应用配置
# 盐值（用于哈希计算）
FABRIC_TRACE_APP_SALT=your-random-salt-value

# CORS 配置
# 允许的来源（逗号分隔，开发环境可设为 http://localhost:9528）
FABRIC_TRACE_CORS_ALLOWED_ORIGINS=http://localhost:9528,http://127.0.0.1:9528

# 环境模式
FABRIC_TRACE_APP_MODE=dev

# 服务器配置
FABRIC_TRACE_APP_IP=127.0.0.1
FABRIC_TRACE_APP_PORT=9090

# 数据库配置
FABRIC_TRACE_MYSQL_HOST=127.0.0.1
FABRIC_TRACE_MYSQL_PORT=3337
FABRIC_TRACE_MYSQL_USER=root
FABRIC_TRACE_MYSQL_DB=fabrictrace

# 安全配置
# bcrypt 成本因子（4-31，推荐 10-12）
FABRIC_TRACE_SECURITY_BCRYPT_COST=10

# 日志配置
# 日志级别：debug, info, warn, error
FABRIC_TRACE_LOG_LEVEL=info
# 日志文件路径（空表示输出到控制台）
# FABRIC_TRACE_LOG_PATH=/var/log/fabric-trace/app.log

# Fabric 区块链配置（Docker 环境需要设置）
# Fabric 加密文件路径（Docker 环境使用 /app/network/...）
# FABRIC_CRYPTO_PATH=/app/network/organizations/peerOrganizations/org1.example.com
# Fabric Peer 节点地址（Docker 环境使用实际IP）
# FABRIC_PEER_ENDPOINT=172.17.0.1:7051
